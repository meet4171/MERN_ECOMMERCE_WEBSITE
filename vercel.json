{
    "builds": [
      {
        "src": "index.js",
        "use": "@vercel/node"
      },
      {
        "src": "build/**",
        "use": "@vercel/static"
      }
    ],
    "routes":[{ "src": "/product-detail/", "dest": "/api/" }
    ],
  
    "rewrites": [{ "source": "/(.*)", "destination": "index.js" }],
    "headers": [
      {
        "source": "/(.*)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=3600"  
          }
        ]
      }
    ]
  }